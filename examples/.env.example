# Copy to .env and fill in. The harness reads these via dotenv.
#
# Get URL + SERVICE_KEY from the Flarelink dashboard:
#   - URL: deployment card → Endpoint
#   - SERVICE_KEY: minted on provision (one-time modal), or rotate via the
#     Authentication page's service-key panel

URL=https://gridsnap-auth.jaan-f97.workers.dev
SERVICE_KEY=flarelink_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# R2 bucket attached to this project (Files page in dashboard). Pre-create
# at least one bucket; the harness creates + reads + deletes a test key
# inside it. Leave blank to skip the storage tests.
BUCKET=
